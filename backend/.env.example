# ---------------------------------------------------------------------------
# Example environment configuration.
# Copy to `.env` and adjust values. All variables use the `PPO_` prefix.
# ---------------------------------------------------------------------------

# --- Application ---
PPO_ENVIRONMENT=development
PPO_DEBUG=true
PPO_APP_VERSION=0.1.0

# --- API / server ---
PPO_HOST=0.0.0.0
PPO_PORT=8000
PPO_API_V1_PREFIX=/api/v1

# --- CORS (comma-separated origins) ---
PPO_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
PPO_LOG_LEVEL=INFO
PPO_LOG_JSON=false

# --- Optimization solver defaults ---
PPO_SOLVER_MAX_TIME_SECONDS=30
PPO_SOLVER_RANDOM_SEED=42

# --- Azure OpenAI (explanation/chat phase; leave blank until then) ---
# Auth: if PPO_AZURE_OPENAI_API_KEY is set, key auth is used; otherwise
# Azure AD token auth (managed identity / az login) is used.
PPO_AZURE_OPENAI_ENDPOINT=
PPO_AZURE_OPENAI_DEPLOYMENT=
PPO_AZURE_OPENAI_API_VERSION=2024-10-21
PPO_AZURE_OPENAI_API_KEY=

# --- Email / SMTP (agentic notification actions) ---
# Used by the "Email risk summary" and "Place order" actions. For Gmail, create
# an App Password and use it as PPO_SMTP_PASSWORD (STARTTLS on port 587).
PPO_SMTP_HOST=smtp.gmail.com
PPO_SMTP_PORT=587
PPO_SMTP_USERNAME=
PPO_SMTP_PASSWORD=
PPO_SMTP_USE_TLS=true
PPO_ALERT_EMAIL_FROM=
PPO_ALERT_EMAIL_TO=
