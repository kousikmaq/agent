# ---- Azure OpenAI (LLM only) ----
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://maqopenai.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ---- Email (SMTP) for the "send alert" action ----
# If left blank, the email action runs in SIMULATION mode (writes to outbox log, sends nothing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=planner-agent@example.com
ALERT_EMAIL_TO=operations@example.com

# ---- App ----
APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
